{
  "name": "study-library-api",
  "version": "1.0.0",
  "description": "Study Library Management System — Express/MongoDB API",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "seed":    "node utils/seeder.js",
    "destroy": "node utils/seeder.js --destroy",
    "test":    "jest --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs":   "^2.4.3",
    "cors":       "^2.8.5",
    "dotenv":     "^16.4.5",
    "express":    "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "helmet":     "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose":   "^8.3.2",
    "morgan":     "^1.10.0",
    "node-cron":  "^3.0.3",
    "nodemailer": "^6.9.13",
    "razorpay":   "^2.9.2"
  },
  "devDependencies": {
    "jest":                  "^29.7.0",
    "nodemon":               "^3.1.3",
    "supertest":             "^7.0.0",
    "mongodb-memory-server": "^9.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

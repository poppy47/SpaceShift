# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/study-library
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/study-library
MONGO_URI=mongodb://127.0.0.1:27017/study-library

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_very_long_random_secret_string_here
JWT_REFRESH_SECRET=replace_with_another_very_long_random_secret_here

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail example — use an App Password, not your real password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourlibraryemail@gmail.com
SMTP_PASS=your_gmail_app_password
